# LLM Backend: "openrouter" (recommended), "ollama" (local), or "gemini"
BACKEND=openrouter

# OpenRouter (recommended — fast, cheap with DeepSeek)
MARKETPULSE_API=your_openrouter_key
OPENROUTER_MODEL=deepseek/deepseek-chat-v3

# Ollama (local, free — needs ~5GB RAM)
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_BASE_URL=http://localhost:11434

# Gemini (Google Cloud)
# GEMINI_API_KEY=your_key_here
# MODEL=gemini-2.5-flash

# Simulation
AGENT_COUNT=25
ROUNDS=3
BATCH_SIZE=5

# PostgreSQL (required for persistence + web UI)
# For local: postgresql://user:pass@localhost:5432/marketpulse
# For Docker: set automatically by docker-compose, no need to change
DATABASE_URL=postgresql://marketpulse:marketpulse@localhost:5432/marketpulse
PERSIST_DB=true
